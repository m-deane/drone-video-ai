.DS_Store

# Inherited claude-template maintainer content — not part of this project.
# Disposition (delete/keep/move) is an open prerequisite decision (see spec Open Questions #7).
/README.md
/CHANGELOG.md
/TODO.md
/REVIEW.md
/PROMPTLAB-READINESS.md
/CLAUDE.md
/docs/
/promptlab/
/copilot-studio/
/assets/
/dist/
/site/
/mkdocs.yml
/sync-claude-template.sh
/requirements-promptlab.txt

# Raw footage over 100MB
/_01_examples/instagram_reel_v34_all_kb_full.mp4
/_01_examples/viral_test_v2_4k.mp4

# Pipeline outputs — regenerable from manifests + raw footage, per plan.md's
# retention convention (spec Open Question #2). data/manifests/ (small JSON)
# is intentionally NOT ignored — safe to commit selectively.
/data/interim/
/data/output/
/data/reference_pack/media/*
!/data/reference_pack/media/.gitkeep

# Python
/.venv/
__pycache__/
*.pyc
*.egg-info/
/build/
.pytest_cache/

# Browser-automation scratch artifacts (e.g. reference-pack editorial_style
# "live_playback_review" attempts) — never intentional deliverables, and a
# frame-capture PNG of an all-rights-reserved source video is exactly the
# kind of footage-adjacent artifact this project's reference pack must never
# persist (spec Scope-out). Clean up loose ones at the repo root too.
/.playwright-mcp/
/seek*.png
/short*.png
/shot-initial.png
